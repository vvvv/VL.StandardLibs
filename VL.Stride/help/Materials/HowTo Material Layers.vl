          <Pad Id="AOtVZMRUQWDOpp2v7vJFau" Bounds="92,420,280,107" ShowValueBox="true" isIOBox="true" Value="Use 'MaterialLayer' with the 'Blend Map' set to a grayscale texture to blend materials on top of each other. The 'Blend Map' acts as a Mask, where the brighter areas allow the top Material to appear.&#xD;&#xA;">
            <p:TypeAnnotation LastCategoryFullName="Primitive" LastDependency="CoreLibBasics.vl">
              <Choice Kind="TypeFlag" Name="String" />
            </p:TypeAnnotation>
            <p:ValueBoxSettings>
