            </p:ValueBoxSettings>
          </Pad>
          <Pad Id="N4z1CV4qsY6LEXQVONeXnu" Bounds="65,563,290,176" ShowValueBox="true" isIOBox="true" Value="Note:&#xD;&#xA;&#xD;&#xA;- 'FromValue' can be replaced with 'Cons' to blend several Material Layers.&#xD;&#xA;&#xD;&#xA;- The material from point 2 has also the 'Layers' pin, so another Material Layer can be applied on top of this one resulting in a deep hierarchy.">
            <p:TypeAnnotation LastCategoryFullName="Primitive" LastDependency="CoreLibBasics.vl">
              <Choice Kind="TypeFlag" Name="String" />
            </p:TypeAnnotation>
            <p:ValueBoxSettings>
              <p:fontsize p:Type="Int32">9</p:fontsize>
