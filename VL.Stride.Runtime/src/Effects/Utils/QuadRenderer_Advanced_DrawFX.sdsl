shader QuadRenderer_Advanced_DrawFX : VS_PS_Base, ColorBase, ShaderUtils
{
    [Default(1, 1, 1, 1)]
    compose ComputeColor ColorInput;

    override stage void VSMain()
    {
        streams.ShadingPosition = mul(streams.Position, WorldViewProjection);
    }

    override stage void PSMain() 
    {
        streams.ColorTarget = ColorInput.Compute();
    }
};