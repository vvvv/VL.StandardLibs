{
  "profiles": {
    "Normal startup": {
      "commandName": "Executable",
      "executablePath": "$(VVVVInstallPath)\\vvvv.exe",
      "commandLineArgs": "--package-repositories $(ThisPackageRepository)"
    },
    "Work on CoreLib": {
      "commandName": "Executable",
      "executablePath": "$(VVVVInstallPath)\\vvvv.exe",
      "commandLineArgs": "--package-repositories $(ThisPackageRepository) --editable-packages VL.CoreLib"
    },
    "Work on Stride": {
      "commandName": "Executable",
      "executablePath": "$(VVVVInstallPath)\\vvvv.exe",
      "commandLineArgs": "--package-repositories $(ThisPackageRepository) --editable-packages VL.Stride*"
    },
    "Work on Serialization": {
      "commandName": "Executable",
      "executablePath": "$(VVVVInstallPath)\\vvvv.exe",
      "commandLineArgs": "--package-repositories $(ThisPackageRepository) --editable-packages VL.Serialization.*"
    },
    "Work on ImGui": {
      "commandName": "Executable",
      "executablePath": "$(VVVVInstallPath)\\vvvv.exe",
      "commandLineArgs": "--package-repositories $(ThisPackageRepository) --editable-packages VL.ImGui*"
    },
    "Work on ImGui.Stride": {
      "commandName": "Executable",
      "executablePath": "$(VVVVInstallPath)\\vvvv.exe",
      "commandLineArgs": "--package-repositories $(ThisPackageRepository) --editable-packages VL.ImGui.Stride"
    },
    "vvvv": {
      "commandName": "Executable",
      "executablePath": "C:\\SMxABB\\Sources\\SpaceMusic\\vvvv-binaries\\vvvv_gamma\\vvvv.exe",
      "commandLineArgs": "--package-repositories \"SpaceMusic;VL.StandardLibs\" --nuget-path \"vvvv-binaries\\nugets\" --editable-packages \"VL.SpaceUI\"",
      "workingDirectory": "C:\\SMxABB\\Sources\\SpaceMusic"
    }
  }
}