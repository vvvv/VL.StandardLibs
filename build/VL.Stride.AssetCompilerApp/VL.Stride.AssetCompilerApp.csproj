<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <!-- Don't pack this, it's build-time infrastructure -->
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Stride.Core.Assets.CompilerApp">
      <ExcludeAssets>build;buildTransitive</ExcludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.Extensions.DependencyModel" />
    <PackageReference Include="Stride.Assets" GeneratePathProperty="true" />
    <!-- It's up to the project what runtime assembly to load (there are multiple) -->
    <PackageReference Include="Stride.Games" ExcludeAssets="runtime" />
  </ItemGroup>

  <ItemGroup>
    <None Include="$(PkgStride_Assets)\contentFiles\any\net8.0\ffmpeg.exe">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="$(PkgStride_Assets)\contentFiles\any\net8.0\msdfgen.exe">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <!-- 
    Remove the Stride.Core.Assets.CompilerApp.exe from runtime assets.
    The NuGet package contains both a .dll and .exe in lib/net8.0,
    but we only want the .dll and its dependencies.
  -->
  <Target Name="RemoveStrideCompilerExe" AfterTargets="ResolvePackageAssets">
    <ItemGroup>
      <RuntimeCopyLocalItems Remove="@(RuntimeCopyLocalItems)" 
                             Condition="'%(Filename)%(Extension)' == 'Stride.Core.Assets.CompilerApp.exe'" />
      <ReferenceCopyLocalPaths Remove="@(ReferenceCopyLocalPaths)" 
                               Condition="'%(Filename)%(Extension)' == 'Stride.Core.Assets.CompilerApp.exe'" />
      <RuntimeTargetsCopyLocalItems Remove="@(RuntimeTargetsCopyLocalItems)"
                                    Condition="'%(Filename)%(Extension)' == 'Stride.Core.Assets.CompilerApp.exe'" />
    </ItemGroup>
  </Target>

</Project>
