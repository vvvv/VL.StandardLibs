          <Pad Id="UTLTQfIN94TPzJfBMXtxfw" Bounds="59,636,616,261" ShowValueBox="true" isIOBox="true" Value="Note, by default the Renderer's space is set to 'Normalized'.&#xD;&#xA;In this space the height of the Renderer is 2 and the width is adjusted proportionally. The center is in the center of the Renderer.&#xD;&#xA;This space can be easily switched.&#xD;&#xA;&#xD;&#xA;When the space is switched to DIP (Device-Independent Pixel) or PixelTopLeft, then the values set for the 'Size' pin of the DrawImage node correspond to pixels:&#xD;&#xA;1 is 100 pixel&#xD;&#xA;1.5 is 150 pixel&#xD;&#xA;2 is 200 pixel&#xD;&#xA;and so on.&#xD;&#xA;&#xD;&#xA;It is possible to have the center of the coordinate system at the top left corner of the Renderer (this is the default for all 2d engines around): DIPTopLeft and PixelTopLeft are exactly for that.">
            <p:TypeAnnotation LastCategoryFullName="Primitive" LastDependency="VL.CoreLib.vl">
              <Choice Kind="TypeFlag" Name="String" />
            </p:TypeAnnotation>
            <p:ValueBoxSettings>
              <p:fontsize p:Type="Int32">9</p:fontsize>
              <p:stringtype p:Assembly="VL.Core" p:Type="VL.Core.StringType">Comment</p:stringtype>
            </p:ValueBoxSettings>
          </Pad>
